            displayCode(code, language) {
                this.originalCode = code;
                const formattedCode = this.formatCodeForDisplay(code, language);
                document.getElementById('codeDisplay').innerHTML = formattedCode;
                this.updateStats(code);
            }

            formatCodeForDisplay(code, language) {
                let formatted = code
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#39;');

                // Syntax highlighting básico
                if (language === 'javascript') {
                    formatted = formatted
                        .replace(/\b(function|const|let|var|if|else|for|while|return|class|extends|import|export|async|await|try|catch|finally)\b/g, '<span class="keyword">$1</span>')
                        .replace(/\b(\d+\.?\d*)\b/g, '<span class="number">$1</span>')
                        .replace(/\b([a-zA-Z_$][a-zA-Z0-9_$]*)\s*\(/g, '<span class="function">$1</span>(')
                        .replace(/('.*?'|".*?"|`.*?`)/g, '<span class="string">$1</span>')
                        .replace(/(\/\/.*$)/gm, '<span class="comment">$1</span>')
                        .replace(/(\/\*[\s\S]*?\*\/)/g, '<span class="comment">$1</span>');
                } else if (language === 'css') {
                    formatted = formatted
                        .replace(/([.#]?[a-zA-Z-]+)\s*{/g, '<span class="highlight">$1</span> {')
                        .replace(/([a-zA-Z-]+)\s*:/g, '<span class="keyword">$1</span>:')
                        .replace(/:\s*([^;]+);/g, ': <span class="string">$1</span>;')
                        .replace(/(\/\*[\s\S]*?\*\/)/g, '<span class="comment">$1</span>');
                } else if (language === 'html') {
                    formatted = formatted
                        .replace(/(&lt;\/?[a-zA-Z][^&gt;]*&gt;)/g, '<span class="keyword">$1</span>')
                        .replace(/([a-zA-Z-]+)=(".*?")/g, '<span class="highlight">$1</span>=<span class="string">$2</span>')
                        .replace(/(&lt;!--[\s\S]*?--&gt;)/g, '<span class="comment">$1</span>');
                }

                return formatted;
            }

            updateStats(code) {
                const lines = code.split('\n').length;
                const chars = code.length;
                const words = code.split(/\s+/).filter(w => w.length > 0).length;
                const kb = (chars / 1024).toFixed(2);

                document.getElementById('linesCount').textContent = lines.toLocaleString();
                document.getElementById('charsCount').textContent = chars.toLocaleString();
                document.getElementById('wordsCount').textContent = words.toLocaleString();
                document.getElementById('sizeCount').textContent = kb;
            }

            copyCode() {
                navigator.clipboard.writeText(this.originalCode).then(() => {
                    this.showNotification('Código copiado al portapapeles ✅');
                });
            }

            downloadCode() {
                const blob = new Blob([this.originalCode], { type: 'text/plain' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `code-${this.currentSection}-${Date.now()}.txt`;
                a.click();
                URL.revokeObjectURL(url);
                this.showNotification('Código descargado ✅');
            }

            searchInCode(searchTerm) {
                if (!searchTerm) {
                    this.displayCode(this.originalCode, this.currentSection);
                    return;
                }

                const highlighted = this.originalCode.replace(
                    new RegExp(searchTerm, 'gi'),
                    `<mark style="background: #ffd93d; color: #000; padding: 2px 4px; border-radius: 3px;">$&</mark>`
                );
                
                this.displayCode(highlighted, this.currentSection);
            }

            formatCode() {
                this.displayCode(this.originalCode, this.currentSection);
                this.showNotification('Código formateado ✨');
            }

            showNotification(message) {
                const notification = document.createElement('div');
                notification.style.cssText = `
                    position: fixed;
                    top: 20px;
                    right: 20px;
                    background: rgba(74, 222, 128, 0.9);
                    color: white;
                    padding: 15px 25px;
                    border-radius: 8px;
                    font-weight: bold;
                    z-index: 1000;
                    animation: slideIn 0.3s ease;
                `;
                notification.textContent = message;
                document.body.appendChild(notification);
                
                setTimeout(() => {
                    notification.style.animation = 'slideOut 0.3s ease';
                    setTimeout(() => notification.remove(), 300);
                }, 2000);
            }
        }

        // Funciones globales para los botones
        function showSection(section) {
            window.codeExplorer.loadSection(section);
        }

        function copyCode() {
            window.codeExplorer.copyCode();
        }

        function downloadCode() {
            window.codeExplorer.downloadCode();
        }

        function formatCode() {
            window.codeExplorer.formatCode();
        }

        // Inicializar la aplicación
        document.addEventListener('DOMContentLoaded', function() {
            window.codeExplorer = new CodeExplorer();
            
            // Agregar estilos para animaciones
            const style = document.createElement('style');
            style.textContent = `
                @keyframes slideIn {
                    from { transform: translateX(100%); opacity: 0; }
                    to { transform: translateX(0); opacity: 1; }
                }
                
                @keyframes slideOut {
                    from { transform: translateX(0); opacity: 1; }
                    to { transform: translateX(100%); opacity: 0; }
                }
                
                mark {
                    background: #ffd93d !important;
                    color: #000 !important;
                    padding: 2px 4px;
                    border-radius: 3px;
                }
                
                .code-display::-webkit-scrollbar {
                    width: 8px;
                }
                
                .code-display::-webkit-scrollbar-track {
                    background: rgba(255, 255, 255, 0.1);
                    border-radius: 4px;
                }
                
                .code-display::-webkit-scrollbar-thumb {
                    background: rgba(255, 255, 255, 0.3);
                    border-radius: 4px;
                }
                
                .code-display::-webkit-scrollbar-thumb:hover {
                    background: rgba(255, 255, 255, 0.5);
                }
            `;
            document.head.appendChild(style);
            
            console.log('🚀 Code Explorer iniciado correctamente');
            console.log('📝 Usa Ctrl+F para buscar, Ctrl+Shift+C para copiar');
        });
    </script>
</body>
</html>
