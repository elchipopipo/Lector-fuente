    <script>
        class CodeExplorer {
            constructor() {
                this.currentSection = 'source';
                this.originalCode = '';
                this.init();
            }

            init() {
                this.setupEventListeners();
                this.loadSection('source');
            }

            setupEventListeners() {
                document.getElementById('searchBox').addEventListener('input', (e) => {
                    this.searchInCode(e.target.value);
                });

                // Atajos de teclado
                document.addEventListener('keydown', (e) => {
                    if (e.ctrlKey || e.metaKey) {
                        switch(e.key) {
                            case 'f':
                                e.preventDefault();
                                document.getElementById('searchBox').focus();
                                break;
                            case 'c':
                                if (e.shiftKey) {
                                    e.preventDefault();
                                    this.copyCode();
                                }
                                break;
                        }
                    }
                });
            }

            loadSection(section) {
                this.currentSection = section;
                this.updateActiveButton(section);
                this.updateTitle(section);
                
                setTimeout(() => {
                    switch(section) {
                        case 'source':
                            this.showHTMLSource();
                            break;
                        case 'javascript':
                            this.showJavaScriptSource();
                            break;
                        case 'css':
                            this.showCSSSource();
                            break;
                        case 'quines':
                            this.showQuineExamples();
                            break;
                        case 'analyzer':
                            this.showAnalyzer();
                            break;
                        case 'docs':
                            this.showDocumentation();
                            break;
                    }
                }, 100);
            }

            updateActiveButton(section) {
                document.querySelectorAll('.nav-button').forEach(btn => {
                    btn.classList.remove('active');
                });
                event.target.classList.add('active');
            }

            updateTitle(section) {
                const titles = {
                    'source': 'Código Fuente HTML',
                    'javascript': 'JavaScript',
                    'css': 'Estilos CSS',
                    'quines': 'Quines & Ejemplos',
                    'analyzer': 'Analizador de Código',
                    'docs': 'Documentación'
                };
                document.getElementById('contentTitle').textContent = titles[section];
            }

            showHTMLSource() {
                const sourceCode = document.documentElement.outerHTML;
                this.displayCode(sourceCode, 'html');
            }

            showJavaScriptSource() {
                const scriptTags = document.querySelectorAll('script');
                let jsCode = '';
                
                scriptTags.forEach(script => {
                    if (script.innerHTML.trim()) {
                        jsCode += script.innerHTML + '\n\n';
                    }
                });

                if (!jsCode) {
                    jsCode = '// No se encontró código JavaScript inline\n// El código está en la clase CodeExplorer';
                }

                this.displayCode(jsCode, 'javascript');
            }

            showCSSSource() {
                const styleTags = document.querySelectorAll('style');
                let cssCode = '';
                
                styleTags.forEach(style => {
                    cssCode += style.innerHTML + '\n\n';
                });

                this.displayCode(cssCode, 'css');
            }

            showQuineExamples() {
                const quineCode = `// === QUINES - Programas Autorreferenciales ===

// 1. Quine simple en JavaScript
function quine() {
    console.log(quine.toString() + "quine()");
}

// 2. Quine más elegante
(function q() {
    console.log('(' + q.toString() + ')()');
})();

// 3. Quine en una línea
$='$=%s;console.log($,$)';console.log($,$);

// 4. Quine en Python
s = 's = %r\\nprint(s %% s)'
print(s % s)

// 5. Quine en C
#include <stdio.h>
char*s="#include <stdio.h>%cchar*s=%c%s%c;%cmain(){printf(s,10,34,s,34,10);}";
main(){printf(s,10,34,s,34,10);}

// 6. Quine en Java
class Q{public static void main(String[]a){char c=34;String s="class Q{public static void main(String[]a){char c=34;String s=%c%s%c;System.out.println(s.format(s,c,s,c));}}";System.out.println(s.format(s,c,s,c));}}

// 7. Quine moderno en JavaScript ES6
const quine = () => {
    const source = \`const quine = \${quine.toString()}; quine();\`;
    console.log(source);
};

// 8. Quine recursivo
function recursive(n) {
    if (n <= 0) return recursive.toString();
    return recursive(n - 1);
}

// === EXPLICACIÓN ===
/*
Un quine es un programa que produce una copia de su propio código fuente.
Debe cumplir estas reglas:
1. No puede leer archivos externos
2. No puede recibir entrada del usuario
3. Debe producir exactamente su código fuente
4. No puede ser trivial (programa vacío)

Los quines son útiles para:
- Entender autorreferencia en programación
- Teoría de la computación
- Desafíos de programación
- Demostrar capacidades del lenguaje
*/`;

                this.displayCode(quineCode, 'javascript');
            }

